<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.alipay.business.common.dal.daointerface.custom.TestMapperDAO">

    <!-- Custom query: select only age and paymentId -->
    <select id="queryIdempotencyKeys" resultType="com.alipay.alipay_plus.common.dal.auto.dataobject.IdempotencyKeysDO">
        SELECT idempotency_key, gmt_create
        FROM idempotency_keys
        WHERE userId = #{userId}
    </select>

</mapper>
