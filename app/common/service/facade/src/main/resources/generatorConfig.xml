<!DOCTYPE generatorConfiguration PUBLIC
        "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "https://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <context id="alipay" targetRuntime="MyBatis3">

        <!-- JDBC connection -->
        <jdbcConnection
                driverClass="org.postgresql.Driver"
                connectionURL="jdbc:postgresql://localhost:5433/user"
                userId="postgres"
                password="1234" />

        <!-- Java Model (DO) generation -->
        <javaModelGenerator
                targetPackage="com.alipay.alipay_plus.common.service.facade.auto.dataobject"
                targetProject="src/main/java"/>

        <!-- Mapper XML generation -->
        <sqlMapGenerator
                targetPackage="sqlmap.idigitalrisk.auto"
                targetProject="src/main/resources"/>

        <!-- Mapper interface generation -->
        <javaClientGenerator
                type="XMLMAPPER"
                targetPackage="com.alipay.alipay_plus.common.service.facade.auto.daointerface"
                targetProject="src/main/java"/>

        <!-- table name, then domain object DO name  -->
        <table tableName="user_info" domainObjectName="UserInfoDO" />
        <table tableName="user_info_detail" domainObjectName="UserInfoDetailDO" />
        <table tableName="user_session" domainObjectName="UserSessionDO" />

    </context>
</generatorConfiguration>
