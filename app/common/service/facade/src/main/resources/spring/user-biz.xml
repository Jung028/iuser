<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:sofa="http://sofastack.io/schema/sofaboot"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
           http://sofastack.io/schema/sofaboot http://sofastack.io/schema/sofaboot.xsd">

    <!-- Scan for Spring components -->
    <context:component-scan base-package="com.alipay.usercenter"/>

    <!-- Publish as SOFABoot service over REST and Bolt -->
    <bean id="userService" class="com.alipay.usercenter.biz.user.impl.UserServiceImpl"/>

    <sofa:service ref="userService" interface="com.alipay.usercenter.common.service.facade.api.UserService">
        <sofa:binding.bolt/>
    </sofa:service>

</beans>