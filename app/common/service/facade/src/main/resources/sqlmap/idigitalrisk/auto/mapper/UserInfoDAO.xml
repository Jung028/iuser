<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.alipay.usercenter.common.dal.auto.custom.UserInfoDAO">

    <!-- Custom query: select only age and paymentId -->
    <select id="queryUserInfo" resultType="com.alipay.usercenter.common.dal.auto.dataobject.UserInfoDO">
        SELECT phoneNo, hashedPassword
        FROM user_info
    </select>

    <update id="insertUserInfo" parameterType="com.alipay.usercenter.common.dal.auto.dataobject.UserInfoDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_info (phoneNo, hashedPassword, age, paymentId)
        VALUES (#{phoneNo}, #{hashedPassword}, #{age}, #{paymentId})
    </update>

</mapper>
