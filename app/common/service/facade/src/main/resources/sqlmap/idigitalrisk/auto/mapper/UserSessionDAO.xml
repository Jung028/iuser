<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.alipay.usercenter.common.dal.auto.custom.UserSessionDAO">

    <!-- Custom query: select only age and paymentId -->
    <select id="queryUserSession" resultType="com.alipay.usercenter.common.dal.auto.dataobject.UserSessionDO">
        SELECT phoneNo, hashedPassword
        FROM user_info
    </select>

</mapper>
